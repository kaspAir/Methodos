# Erweitert das offizielle Jenkins-LTS-Image um den Docker-CLI,
# damit der Jenkinsfile docker.image(...).inside(...) und docker.build(...)
# gegen den Docker Desktop-Daemon ausfuehren kann.
FROM jenkins/jenkins:lts-jdk17

USER root
RUN apt-get update && \
    apt-get install -y --no-install-recommends docker.io && \
    rm -rf /var/lib/apt/lists/* && \
    usermod -aG docker jenkins

USER jenkins
