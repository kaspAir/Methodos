# Kopiere diese Datei zu .env und passe sie an. .env wird NICHT committet.
DATABASE_URL=sqlite:///hermespia.db
FLASK_DEBUG=1

# Sicherheitsschlüssel für Flask-Sessions
# Generieren mit: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Anthropic API (für den Interview-Loop). Schlüssel zu Hause eintragen.
ANTHROPIC_API_KEY=
HERMESPIA_LLM_MODEL=claude-sonnet-4-6

# RAG / Wissenskorpus – Voyage-AI-Embeddings. Ohne Key bleibt das RAG inaktiv.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# Speech-to-Text (Meeting mithören). OpenAI-kompatibler /audio/transcriptions-Endpoint.
# Frei wählbar (OpenAI, Groq, Azure-OpenAI oder self-hosted/CH-gehostete Whisper-Instanz
# – für Behördendaten Datenresidenz beachten!). Ohne Key bleibt die Funktion inaktiv.
STT_API_URL=https://api.openai.com/v1/audio/transcriptions
STT_API_KEY=
STT_MODEL=whisper-1
