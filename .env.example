# Kopiere diese Datei zu .env und passe sie an. .env wird NICHT committet.
DATABASE_URL=sqlite:///methodos.db
FLASK_DEBUG=1

# Sicherheitsschlüssel für Flask-Sessions
# Generieren mit: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Anthropic API (für den Interview-Loop). Schlüssel zu Hause eintragen.
ANTHROPIC_API_KEY=
METHODOS_LLM_MODEL=claude-sonnet-4-6
